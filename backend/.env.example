FLASK_ENV=development
FLASK_APP=wsgi.py
PORT=1489

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# SQLite (dev): относительный путь резолвится относительно папки backend/
DATABASE_URL=sqlite:///database/baiterek.db
# Postgres (prod):
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/baiterek

CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

LOG_LEVEL=INFO
LOG_JSON=false

EISH_BASE_URL=http://localhost:9999/eish-mock
EISH_API_KEY=dev-key
ECP_BASE_URL=http://localhost:9999/ecp-mock
